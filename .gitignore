domains/dev/config/zellij/layouts/solarized.kdl
domains/dev/config/cursor/settings.json
domains/dev/config/codex/config.toml

# Userstyles (generated from templates)
domains/system/userstyles/gen/

# Lock files and generated state files
**/lazy-lock.json
**/lazyvim.json

# Runtime state files (auto-generated)
**/dropdown_windows.json
**/sessions/
**/session*

# Tmux plugins and generated files
**/tmux/plugins/
**/tmux/resurrect/

# Zellij plugins (WASM binaries should be downloaded, not committed)
**/zellij/plugins/*.wasm

# Theme-generated files (auto-generated by theme-switcher)
domains/system/config/colors.lua
domains/system/config/theme-env/
domains/workspace/config/sketchybar/colors.lua
domains/dev/config/tmux/themes/current.conf
**/ghostty/theme
**/borders/colors.sh

# Neovim auto-managed directories
**/nvim*/.lazy/
**/nvim*/spell/

# Neovim theme files (auto-generated by theme-switch)
domains/dev/config/nvim-lazyvim/lua/plugins/colorscheme.lua
domains/dev/config/nvim-astrovim/lua/plugins/colorscheme.lua
domains/dev/config/nvim-nvchad/lua/chadrc.lua
domains/dev/config/nvim-custom/lua/custom/plugins/colorscheme.lua

# Shell history and sessions
.zsh_history
.zsh_sessions
**/.zcompdump*

# Backup directories
**/*.backup/
**/backup/

# User-specific git config (should be local only)
**/git/config.local
**/git/conditional/
**/.gitconfig

# User-specific jj config (should be local only)
**/jj/conf.d/user.toml

# Company-specific configurations (never commit)
**/workspace/config/qlink/

# Raycast (auto-generated configs and extensions)
**/raycast/

# Serena logs
**/serena/logs/

# Nix
result
result-*

# node2nix
domains/*/packages/node2nix/node_modules/
domains/dev/config/claude/cache/
domains/dev/config/claude/paste-cache/
domains/dev/config/claude/tasks/
domains/dev/config/claude/image-cache/
**/claude/security_warnings_state_*.json

# Python cache
**/__pycache__/

# Playwright MCP (browser testing screenshots)
.playwright-mcp/

# Docs build artifacts
docs/dist/
docs/.astro/

# Claude Code cache files
domains/dev/config/claude/mcp-needs-auth-cache.json
domains/dev/config/claude/policy-limits.json
domains/dev/config/claude/metrics/
domains/dev/config/claude/chrome/chrome-native-host
domains/dev/config/claude/teams/

# Zed editor state
**/zed/prompts/prompts-library-db.0.mdb/lock.mdb

# hooks-toggle runtime state
domains/dev/config/claude/hooks-registry.json
domains/dev/config/claude/hooks-disabled.json
domains/dev/config/claude/hooks-toggle.sh

# Runtime toggle flags (chooks)
domains/dev/config/claude/.english-coach
domains/dev/config/claude/.auto-mode

# Lock files
domains/dev/config/claude/version-cache.json.lock
