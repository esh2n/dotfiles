.DS_Store
*.backup.*
*.bak*
*.swp
*.log
tmp/
log/

# Security - Never commit these
**/auth.json
**/credentials.json
**/*secret*.json
**/*token*.json
**/*.pem
**/*.key
**/.env
**/.env.local
**/.env.*.local

# Application state - Never commit
**/sessions/
**/session*
**/*history*.jsonl
**/*history*.json
**/node_modules/

# Claude specific
**/claude/telemetry/
**/claude/debug/
**/claude/file-history/
**/claude/ide/
**/claude/local/
**/claude/plans/
**/claude/plugins/
**/claude/projects/
**/claude/shell-snapshots/
**/claude/stats-cache.json
**/claude/version-cache.json
**/claude/homunculus/
**/claude/statsig/
**/claude/todos/
.claude/

# Codex specific
**/codex/sessions/
**/codex/history.jsonl

# Generated from templates (do not commit)
domains/dev/config/vscode/settings.json
# Generated by claude-switch merge (do not commit)
domains/dev/config/claude/settings.json
domains/dev/config/claude/CLAUDE.md
domains/dev/config/claude/agents
domains/dev/config/claude/commands
domains/dev/config/claude/hooks
domains/dev/config/claude/rules
domains/dev/config/claude/scripts
domains/dev/config/claude/skills
domains/dev/config/claude/.*-merged/
domains/dev/config/starship/starship.toml
domains/dev/config/mise/config.toml
domains/dev/config/zellij/config.kdl
domains/dev/config/zellij/layouts/default.kdl
domains/dev/config/zellij/layouts/nord.kdl
domains/dev/config/zellij/layouts/tokyonight.kdl
domains/dev/config/zellij/layouts/catppuccin.kdl
domains/dev/config/zellij/layouts/kanagawa.kdl
domains/dev/config/zellij/layouts/gruvbox.kdl
domains/dev/config/zellij/layouts/dracula.kdl
domains/dev/config/zellij/layouts/rosepine.kdl
domains/dev/config/zellij/layouts/everforest.kdl
