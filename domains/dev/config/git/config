# Portable git config (committed to dotfiles)
# Loaded automatically as $XDG_CONFIG_HOME/git/config
# Machine-specific overrides go in conditional/*.conf (gitignored)

# Theme-aware delta colors (generated by theme-switch to XDG location)
[include]
    path = ~/.config/git/delta-theme.gitconfig

[alias]
    uncommit = reset --soft HEAD^
    unpushed = log @{u}.. --oneline
    gone = "!git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' refs/heads | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D"
    quicksave = "!git add -A && git commit --no-verify -m \"quicksave-$(date +%Y%m%d-%H%M%S)\" && git reset HEAD~"
    home = "!f() { git switch \"$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')\" 2>/dev/null || git switch main 2>/dev/null || git switch master; }; f"
    default-branch = "!git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@'"

[pager]
    diff = diffnav
    log = ov
    show = delta | ov
