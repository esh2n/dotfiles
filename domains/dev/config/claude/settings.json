{
  "apiKeyHelper": "",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDECODE": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_COST_WARNINGS": "0",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "SHELL": "/opt/homebrew/bin/fish",
    "UV_CACHE_DIR": "~/.cache/uv",
    "UV_PYTHON_PREFERENCE": "managed",
    "DENO_DIR": "~/.cache/deno",
    "CARGO_HOME": "~/.cargo",
    "RUSTUP_HOME": "~/.rustup",
    "GOPATH": "~/go",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "LS(**)",
      "TodoRead(**)",
      "TodoWrite(**)",
      "Task(**)",
      "WebSearch",
      "NotebookRead(**)",

      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git fetch *)",
      "Bash(git stash list *)",
      "Bash(git worktree list *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git ls-files *)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(git describe *)",
      "Bash(git config --get *)",
      "Bash(git tag -l *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",

      "Bash(ls *)",
      "Bash(eza *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(env)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(date *)",
      "Bash(mkdir *)",
      "Bash(echo *)",
      "Bash(sort *)",
      "Bash(readlink *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(* --version)",
      "Bash(* --help)",

      "Edit(./**)",
      "Edit(~/.claude/**)",
      "Edit(~/.config/**)",
      "Write(./**)",
      "Write(~/.claude/**)",
      "Write(~/.config/**)",
      "MultiEdit(./**)",
      "MultiEdit(~/.claude/**)",
      "MultiEdit(~/.config/**)",
      "NotebookEdit(./**)",

      "WebFetch(domain:*)"
    ],
    "deny": [
      "Read(**.env)",
      "Read(**.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.azure/**)",
      "Read(~/.gcp/**)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*_rsa)",
      "Read(~/.ssh/*_ecdsa)",
      "Read(~/.ssh/*_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",

      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo rm *)",
      "Bash(sudo dd *)",
      "Bash(sudo mkfs *)",
      "Bash(sudo fdisk *)",
      "Bash(sudo mount *)",
      "Bash(sudo umount *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(> /dev/*)",
      "Bash(>> /dev/*)",
      "Bash(sudo passwd *)",
      "Bash(sudo -i *)",
      "Bash(sudo su *)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- .)",
      "Bash(git clean -fd *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf .git)",

      "Bash(terraform destroy *)",
      "Bash(terragrunt destroy *)",
      "Bash(az account clear *)",
      "Bash(az logout *)",
      "Bash(az group delete *)",
      "Bash(az vm delete *)",
      "Bash(az storage account delete *)",
      "Bash(gcloud auth revoke *)",
      "Bash(gcloud projects delete *)",
      "Bash(gcloud compute instances delete *)",
      "Bash(gcloud sql instances delete *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete all *)",
      "Bash(helm uninstall *)",

      "Bash(az keyvault secret show *)",
      "Bash(gcloud secrets versions access *)",
      "Bash(kubectl get secrets *)",

      "Bash(npm publish *)",
      "Bash(cargo publish *)",
      "Bash(deno publish *)",
      "Bash(dotnet nuget push *)",

      "Bash(docker system prune *)",
      "Bash(kill -9 *)",

      "Edit(/etc/**)",
      "Edit(/usr/**)",
      "Edit(/var/**)",
      "Edit(/opt/**)",
      "Edit(/bin/**)",
      "Edit(/sbin/**)",
      "Edit(/lib/**)",
      "Edit(/boot/**)",
      "Edit(/proc/**)",
      "Edit(/sys/**)",
      "Edit(/dev/**)",
      "Edit(~/.ssh/id_*)",
      "Edit(~/.ssh/*_rsa)",
      "Edit(~/.ssh/*_ecdsa)",
      "Edit(~/.ssh/*_ed25519)",
      "Edit(~/.aws/credentials)",
      "Edit(~/.azure/**)",
      "Edit(~/.gcp/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(/opt/**)",
      "Write(/bin/**)",
      "Write(/sbin/**)",
      "Write(/lib/**)",
      "Write(/boot/**)",
      "Write(/proc/**)",
      "Write(/sys/**)",
      "Write(/dev/**)",
      "Write(~/.ssh/id_*)",
      "Write(~/.ssh/*_rsa)",
      "Write(~/.ssh/*_ecdsa)",
      "Write(~/.ssh/*_ed25519)",
      "Write(~/.aws/credentials)",
      "Write(~/.azure/**)",
      "Write(~/.gcp/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-format.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-test.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/mcp-audit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-info.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/compact-context.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"承認が必要です\" with title \"Claude Code\" sound name \"Ping\"'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスク完了\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": []
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "Notion@claude-plugins-official": true
  },
  "language": "Japanese",
  "mcpServers": {
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [],
      "env": {},
      "type": "stdio"
    }
  },
  "theme": "dark",
  "preferredNotifChannel": "ghostty"
}
