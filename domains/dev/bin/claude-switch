#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------------
# Claude Code Config Composer (packs edition)
# -----------------------------------------------------------------------------
# Composes ~/.claude from three layers:
#   base/   — personal, always-on skills/hooks/commands/scripts
#   core/   — curated universal content (vendored from ECC, see ECC_VERSION)
#   packs/  — optional per-language/domain sets, toggled per machine
#
# Enabled packs live in ~/.claude/.claude-packs (seeded from packs.default).
# Hook runtime is vendored under runtime/ecc — no external checkout needed.
# `ecc-sync` (maintainer only) refreshes runtime/ from the upstream ECC repo.
# -----------------------------------------------------------------------------

# Resolve DOTFILES_ROOT from script's own location (works via symlink)
if [[ -z "${DOTFILES_ROOT:-}" ]]; then
    SCRIPT_REALPATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c "import os; print(os.path.realpath('${BASH_SOURCE[0]}'))" 2>/dev/null || echo "")"
    if [[ -n "$SCRIPT_REALPATH" ]]; then
        # Script is at $DOTFILES_ROOT/domains/dev/bin/claude-switch
        DOTFILES_ROOT="$(cd "$(dirname "$SCRIPT_REALPATH")/../../.." && pwd)"
    fi
fi

# Load utilities (with fallbacks so the script works standalone)
if [[ -n "${DOTFILES_ROOT:-}" && -f "$DOTFILES_ROOT/core/utils/common.sh" ]]; then
    source "$DOTFILES_ROOT/core/utils/common.sh"
elif [[ -f "$HOME/dotfiles/core/utils/common.sh" ]]; then
    source "$HOME/dotfiles/core/utils/common.sh"
fi
type log_info    >/dev/null 2>&1 || log_info()    { echo "[info] $*"; }
type log_success >/dev/null 2>&1 || log_success() { echo "[ok] $*"; }
type log_warn    >/dev/null 2>&1 || log_warn()    { echo "[warn] $*"; }
type log_error   >/dev/null 2>&1 || log_error()   { echo "[error] $*" >&2; }

# Resolve profiles directory
PROFILES_DIR=""
for candidate in \
    "${DOTFILES_ROOT:-}/domains/dev/config/claude-profiles" \
    "$HOME/dotfiles/domains/dev/config/claude-profiles"; do
    if [[ -d "$candidate" ]]; then
        PROFILES_DIR="$candidate"
        break
    fi
done

if [[ -z "$PROFILES_DIR" ]]; then
    log_error "claude-profiles directory not found"
    exit 1
fi

CLAUDE_DIR="$HOME/.claude"
CURSOR_DIR="$HOME/.cursor"
BASE_DIR="$PROFILES_DIR/base"
CORE_DIR="$PROFILES_DIR/core"
PACKS_DIR="$PROFILES_DIR/packs"
RUNTIME_DIR="$PROFILES_DIR/runtime/ecc"
PACKS_FILE="$CLAUDE_DIR/.claude-packs"
PACKS_DEFAULT="$PROFILES_DIR/packs.default"

# Components merged across base + core + enabled packs
MERGE_DIRS=(skills hooks scripts commands agents rules)

# -----------------------------------------------------------------------------
# pack helpers
# -----------------------------------------------------------------------------
available_packs() {
    find "$PACKS_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
}

enabled_packs() {
    if [[ ! -f "$PACKS_FILE" ]]; then
        if [[ -f "$PACKS_DEFAULT" ]]; then
            mkdir -p "$CLAUDE_DIR"
            cp "$PACKS_DEFAULT" "$PACKS_FILE"
        else
            touch "$PACKS_FILE"
        fi
    fi
    grep -vE '^\s*(#|$)' "$PACKS_FILE" 2>/dev/null | sort -u
}

pack_is_enabled() {
    enabled_packs | grep -qx "$1"
}

save_packs() {
    # $@ = pack names
    mkdir -p "$CLAUDE_DIR"
    printf '%s\n' "$@" | sort -u | grep -vE '^\s*$' > "$PACKS_FILE" || true
}

validate_pack() {
    if [[ ! -d "$PACKS_DIR/$1" ]]; then
        log_error "Unknown pack: $1"
        log_info "Available: $(available_packs | tr '\n' ' ')"
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# merge settings.json (base + core layer → output)
# -----------------------------------------------------------------------------
merge_settings() {
    local base="$BASE_DIR/settings.base.json"
    local layer="$CORE_DIR/settings.layer.json"
    local output="$CLAUDE_DIR/settings.json"

    if [[ ! -f "$base" ]]; then
        log_error "Base settings not found: $base"
        exit 1
    fi
    if [[ ! -f "$layer" ]]; then
        log_error "Core settings not found: $layer"
        exit 1
    fi

    local dotfiles_parent
    dotfiles_parent="$(dirname "${DOTFILES_ROOT:-$HOME/dotfiles}")"

    jq -s '
      .[0] as $base | .[1] as $layer |
      ($base * $layer) |
      .permissions.allow = (
        ($base.permissions.allow // []) + ($layer.permissions.allow // []) | unique
      ) |
      .permissions.deny = ($base.permissions.deny // []) |
      .hooks = (
        ($base.hooks // {}) as $bh | ($layer.hooks // {}) as $lh |
        ($bh | keys) + ($lh | keys) | unique |
        map(. as $k | {($k): (($bh[$k] // []) + ($lh[$k] // []))}) |
        add // {}
      ) |
      .mcpServers = (($base.mcpServers // {}) + ($layer.mcpServers // {})) |
      .enabledPlugins = (($base.enabledPlugins // {}) + ($layer.enabledPlugins // {})) |
      .extraKnownMarketplaces = (
        ($base.extraKnownMarketplaces // {}) + ($layer.extraKnownMarketplaces // {})
      ) |
      .env = (($base.env // {}) + ($layer.env // {}))
    ' "$base" "$layer" \
      | sed "s|{{DOTFILES_PARENT}}|${dotfiles_parent}|g" \
      | sed "s|{{DOTFILES_ROOT}}|${DOTFILES_ROOT:-$HOME/dotfiles}|g" \
      | sed "s|{{HOME}}|${HOME}|g" \
      > "$output"
}

# -----------------------------------------------------------------------------
# merge CLAUDE.md (base + core layer → output)
# -----------------------------------------------------------------------------
merge_claude_md() {
    local base="$BASE_DIR/CLAUDE.base.md"
    local layer="$CORE_DIR/CLAUDE.layer.md"
    local output="$CLAUDE_DIR/CLAUDE.md"

    if [[ -f "$base" && -f "$layer" ]]; then
        cat "$base" > "$output"
        printf "\n\n" >> "$output"
        cat "$layer" >> "$output"
    elif [[ -f "$base" ]]; then
        cp "$base" "$output"
    elif [[ -f "$layer" ]]; then
        cp "$layer" "$output"
    fi
}

# -----------------------------------------------------------------------------
# merge_dir: base/{dir} + core/{dir} + packs/<enabled>/{dir} → staging symlinks
# -----------------------------------------------------------------------------
merge_dir() {
    local dir_name="$1"; shift
    local packs=("$@")
    local stage="$CLAUDE_DIR/.${dir_name}-merged"
    local link="$CLAUDE_DIR/$dir_name"

    if [[ -d "$stage" ]]; then
        find "$stage" -mindepth 1 -delete
    else
        mkdir -p "$stage"
    fi

    local total=0
    local -a sources=("$BASE_DIR/$dir_name" "$CORE_DIR/$dir_name")
    local p
    for p in "${packs[@]}"; do
        sources+=("$PACKS_DIR/$p/$dir_name")
    done

    local src item name
    for src in "${sources[@]}"; do
        [[ -d "$src" ]] || continue
        for item in "$src"/*; do
            [[ -e "$item" || -L "$item" ]] || continue
            name="$(basename "$item")"
            ln -sfn "$item" "$stage/$name"
            ((total++)) || true
        done
    done

    if [[ -d "$link" && ! -L "$link" ]]; then
        mv "$link" "$link.backup.$(date +%Y%m%d-%H%M%S)"
    fi
    [[ -L "$link" ]] && rm "$link"
    ln -sfn "$stage" "$link"

    log_success "Merged $dir_name: $total items"
}

# -----------------------------------------------------------------------------
# link_cursor_rules: vendored ECC cursor rules → ~/.cursor/rules
# -----------------------------------------------------------------------------
link_cursor_rules() {
    local src="$RUNTIME_DIR/.cursor/rules"
    [[ -d "$src" ]] || return 0
    mkdir -p "$CURSOR_DIR/rules"
    local rule name count=0
    for rule in "$src"/*; do
        [[ -e "$rule" ]] || continue
        name="$(basename "$rule")"
        ln -sfn "$rule" "$CURSOR_DIR/rules/$name"
        ((count++)) || true
    done
    log_success "Cursor: linked $count rules → ~/.cursor/rules/"
}

# -----------------------------------------------------------------------------
# apply: rebuild ~/.claude from base + core + enabled packs
# -----------------------------------------------------------------------------
apply() {
    local -a packs=()
    while IFS= read -r p; do
        [[ -n "$p" ]] || continue
        if [[ -d "$PACKS_DIR/$p" ]]; then
            packs+=("$p")
        else
            log_warn "Enabled pack not found, skipping: $p"
        fi
    done < <(enabled_packs)

    log_info "Applying: base + core + packs(${packs[*]:-none})"

    merge_settings
    log_success "Merged settings.json (base + core)"

    merge_claude_md
    log_success "Merged CLAUDE.md (base + core)"

    local dir
    for dir in "${MERGE_DIRS[@]}"; do
        merge_dir "$dir" "${packs[@]+"${packs[@]}"}"
    done

    link_cursor_rules

    # Legacy marker no longer used; keep it pointing at the new scheme
    echo "packs" > "$CLAUDE_DIR/.claude-profile"

    echo ""
    log_success "Applied. Enabled packs: ${packs[*]:-none}"
    log_info "Restart claude-cli to apply changes"
}

# -----------------------------------------------------------------------------
# interactive pack picker (no external dependencies)
# -----------------------------------------------------------------------------
interactive() {
    local -a all=() state=()
    local p i
    while IFS= read -r p; do all+=("$p"); done < <(available_packs)

    for i in "${!all[@]}"; do
        if pack_is_enabled "${all[$i]}"; then state[$i]=1; else state[$i]=0; fi
    done

    while true; do
        echo ""
        echo "Packs (toggle by number, 'a' = apply, 'q' = quit without applying):"
        for i in "${!all[@]}"; do
            local mark="[ ]"
            [[ "${state[$i]}" == 1 ]] && mark="[x]"
            printf "  %2d. %s %s\n" "$((i + 1))" "$mark" "${all[$i]}"
        done
        printf "> "
        local input
        read -r input || { echo ""; return 1; }
        case "$input" in
            a|A)
                local -a chosen=()
                for i in "${!all[@]}"; do
                    [[ "${state[$i]}" == 1 ]] && chosen+=("${all[$i]}")
                done
                save_packs "${chosen[@]+"${chosen[@]}"}"
                apply
                return 0
                ;;
            q|Q)
                log_info "Aborted (no changes)"
                return 0
                ;;
            *)
                local n
                for n in $input; do
                    if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#all[@]} )); then
                        i=$((n - 1))
                        state[$i]=$((1 - state[$i]))
                    else
                        log_warn "Invalid selection: $n"
                    fi
                done
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# ecc-sync: refresh runtime/ (and report content drift) from upstream ECC repo
# Maintainer-only; regular users of the dotfiles never need this.
# -----------------------------------------------------------------------------
ecc_sync() {
    local ref="${1:-origin/main}"
    local dotfiles_parent
    dotfiles_parent="$(dirname "${DOTFILES_ROOT:-$HOME/dotfiles}")"
    local ecc_repo="${ECC_ROOT:-${dotfiles_parent}/everything-claude-code}"

    if [[ ! -d "$ecc_repo/.git" ]]; then
        log_error "ECC repo not found: $ecc_repo (clone affaan-m/everything-claude-code or set ECC_ROOT)"
        exit 1
    fi

    log_info "Fetching $ecc_repo ..."
    git -C "$ecc_repo" fetch --quiet origin

    local sha
    sha="$(git -C "$ecc_repo" rev-parse "$ref")"
    local old_sha=""
    [[ -f "$PROFILES_DIR/ECC_VERSION" ]] && old_sha="$(grep '^commit:' "$PROFILES_DIR/ECC_VERSION" | awk '{print $2}')"

    if [[ "$sha" == "$old_sha" ]]; then
        log_success "runtime already at $ref ($sha) — nothing to sync"
        return 0
    fi

    local paths=(scripts/hooks scripts/lib skills/continuous-learning-v2 .cursor/rules LICENSE)
    log_info "Syncing runtime from $ref (${sha:0:12}) ..."
    local d
    for d in scripts/hooks scripts/lib skills/continuous-learning-v2 .cursor/rules; do
        /bin/rm -rf "${RUNTIME_DIR:?}/$d"
    done
    mkdir -p "$RUNTIME_DIR"
    git -C "$ecc_repo" archive "$sha" -- "${paths[@]}" | tar -x -C "$RUNTIME_DIR"

    {
        echo "source: https://github.com/affaan-m/everything-claude-code"
        echo "commit: $sha"
        echo "synced: $(date +%Y-%m-%d)"
        echo "paths: ${paths[*]}"
    } > "$PROFILES_DIR/ECC_VERSION"

    log_success "runtime updated → $sha"
    if [[ -n "$old_sha" ]]; then
        echo ""
        log_info "Upstream content changes since last sync (review manually if interested):"
        git -C "$ecc_repo" diff --stat "$old_sha" "$sha" -- skills agents commands rules 2>/dev/null | tail -1 || true
        log_info "  git -C $ecc_repo log --oneline $old_sha..$sha -- skills agents commands rules"
    fi
    log_info "Run 'claude-switch apply' to activate, then smoke-test a session."
}

# -----------------------------------------------------------------------------
# status output
# -----------------------------------------------------------------------------
show_status() {
    echo "Enabled packs:"
    local p
    while IFS= read -r p; do
        [[ -n "$p" ]] && echo "  * $p"
    done < <(enabled_packs)
    echo ""
    echo "Available packs:"
    while IFS= read -r p; do
        if pack_is_enabled "$p"; then
            echo "  [x] $p"
        else
            echo "  [ ] $p"
        fi
    done < <(available_packs)
    if [[ -f "$PROFILES_DIR/ECC_VERSION" ]]; then
        echo ""
        echo "Runtime (vendored ECC):"
        sed 's/^/  /' "$PROFILES_DIR/ECC_VERSION"
    fi
}

# -----------------------------------------------------------------------------
# Entry point
# -----------------------------------------------------------------------------
case "${1:-}" in
    "")
        interactive
        ;;
    apply)
        apply
        ;;
    pack)
        case "${2:-}" in
            list|"")
                show_status
                ;;
            enable)
                shift 2
                [[ $# -ge 1 ]] || { log_error "Usage: claude-switch pack enable <pack>..."; exit 1; }
                for p in "$@"; do validate_pack "$p"; done
                declare -a current=()
                while IFS= read -r c; do [[ -n "$c" ]] && current+=("$c"); done < <(enabled_packs)
                save_packs "${current[@]+"${current[@]}"}" "$@"
                apply
                ;;
            disable)
                shift 2
                [[ $# -ge 1 ]] || { log_error "Usage: claude-switch pack disable <pack>..."; exit 1; }
                declare -a current=()
                while IFS= read -r c; do [[ -n "$c" ]] && current+=("$c"); done < <(enabled_packs)
                declare -a kept=()
                for c in "${current[@]+"${current[@]}"}"; do
                    keep=1
                    for p in "$@"; do [[ "$c" == "$p" ]] && keep=0; done
                    [[ $keep == 1 ]] && kept+=("$c")
                done
                save_packs "${kept[@]+"${kept[@]}"}"
                apply
                ;;
            *)
                log_error "Usage: claude-switch pack {list|enable|disable} [pack...]"
                exit 1
                ;;
        esac
        ;;
    current|list|status)
        show_status
        ;;
    ecc-sync)
        ecc_sync "${2:-}"
        ;;
    ecc|custom)
        log_warn "Profiles are gone — config is now base + core + packs."
        log_warn "Use 'claude-switch pack list' to see packs. Applying current selection..."
        apply
        ;;
    *)
        echo "Usage: claude-switch [command]"
        echo ""
        echo "  (no args)                     Interactive pack selection, then apply"
        echo "  apply                         Rebuild ~/.claude from base + core + enabled packs"
        echo "  pack list                     Show enabled/available packs"
        echo "  pack enable <pack>...         Enable pack(s) and apply"
        echo "  pack disable <pack>...        Disable pack(s) and apply"
        echo "  status                        Same as 'pack list'"
        echo "  ecc-sync [ref]                (maintainer) refresh vendored runtime from ECC repo"
        echo ""
        echo "Layers: base (personal, always on) + core (universal) + packs (per language/domain)"
        echo "Enabled packs: ~/.claude/.claude-packs (defaults: packs.default)"
        exit 1
        ;;
esac
