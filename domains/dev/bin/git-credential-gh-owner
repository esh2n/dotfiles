#!/usr/bin/env bash
set -euo pipefail

[[ "${1:-}" == get ]] || exit 0
command -v gh >/dev/null || exit 0

request=$(cat)
delegate() { printf '%s\n' "$request" | gh auth git-credential get; exit 0; }

owner=$(awk -F= '$1 == "path" { print $2 }' <<<"$request")
owner=${owner%%/*}
[[ -n $owner ]] || delegate

account=$(git config --get "credentialAccount.${owner}.account" 2>/dev/null || true)
account=${account:-$owner}

token=$(gh auth token --user "$account" 2>/dev/null) && [[ -n $token ]] || delegate
printf 'username=%s\npassword=%s\n' "$account" "$token"
